@model IEnumerable<ItemHierarchyApp.Models.Item>

<h2 class="mb-3">Items List</h2>

<!-- 🔍 Search -->
<form method="get" class="mb-3">
    <input type="text" name="searchString" 
           value="@Context.Request.Query["searchString"]" 
           placeholder="Search items..." class="form-control w-25 d-inline" />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

<!-- ➕ Navigation -->
<p>
    <a href="/Item/Create" class="btn btn-success">Add New Item</a>
    <a href="/Item/Tree" class="btn btn-info">View Tree</a>
</p>

<!-- ✅ Responsive Full Width Table -->
<div class="table-responsive">
    <table class="table table-bordered table-striped w-100">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Weight</th>
                <th>Actions</th>
                <th>Children</th>
            </tr>
        </thead>

        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center">No items found</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@(item.Weight)</td>
                    <td>
                        <a href="/Item/Edit/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a href="/Item/Delete/@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        <a href="/Item/Process/@item.Id" class="btn btn-sm btn-primary">Add Child</a>
                    </td>
                    <td>
                        @if(item.Children != null && item.Children.Count > 0)
                        {
                            <ul>
                                @foreach(var child in item.Children)
                                {
                                    <li>@child.Name (@(child.Weight))</li>
                                }
                            </ul>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>