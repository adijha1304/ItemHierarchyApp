@model ItemHierarchyApp.Models.Item

<h2>Add Children to: @Model.Name</h2>

<form asp-action="Process" method="post">
    <input type="hidden" name="parentId" value="@Model.Id" />

    <div id="children-container">
        <div class="child-item">
            <label>Child Name:</label>
            <input name="children[0].Name" required />

            <label>Child Weight:</label>
            <input name="children[0].Weight" type="number" step="0.01" required />
        </div>
    </div>

    <br />

    <button type="button" id="add-more">+ Add Another Child</button>

    <br /><br />

    <button type="submit">Save Children</button>
    <a href="/Item/Index">Cancel</a>
</form>

@section Scripts {
    <script>
        let counter = 1;

        document.getElementById("add-more").addEventListener("click", function() {
            const container = document.getElementById("children-container");

            const div = document.createElement("div");
            div.classList.add("child-item");

            div.innerHTML = `
                <label>Child Name:</label>
                <input name="children[${counter}].Name" required />

                <label>Child Weight:</label>
                <input name="children[${counter}].Weight" type="number" step="0.01" required />
            `;

            container.appendChild(div);
            counter++;
        });
    </script>
}